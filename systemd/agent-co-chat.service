[Unit]
Description=agent-co Chat Service
After=network.target redis-server.service agent-co-auth-admin.service
Requires=redis-server.service agent-co-auth-admin.service

[Service]
Type=simple
WorkingDirectory=__APP_DIR__
ExecStartPre=/bin/sh -c 'redis-cli -u "redis://127.0.0.1:6379" ping | grep -q PONG'
ExecStart=/usr/bin/node __APP_DIR__/dist/server.js
Restart=always
RestartSec=2
User=root
Group=root
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ProtectHome=false
ReadOnlyPaths=__APP_DIR__/public

[Install]
WantedBy=multi-user.target
