# ── shared ──
NODE_ENV=production

# ── chat service (port 3002) ──
PORT=3002
AGENT_CO_AUTH_ENABLED=true
AUTH_ADMIN_BASE_URL=http://127.0.0.1:3003

# ── auth-admin service (port 3003) ──
AUTH_ADMIN_PORT=3003
AUTH_ADMIN_TOKEN=please-change-this-token
AUTH_DATA_FILE=/opt/agent-co/data/users.json
AGENT_CO_DEFAULT_USER=admin
AGENT_CO_DEFAULT_PASSWORD=ChangeMe123!
