{
  "name": "multi-agent-chat",
  "version": "1.0.0",
  "description": "Multi AI Agent Chat Room",
  "main": "dist/server.js",
  "scripts": {
    "init": "bash scripts/init-dev.sh",
    "build": "rm -rf dist && tsc -p tsconfig.json",
    "start": "npm run start:chat",
    "dev": "ts-node src/server.ts",
    "start:chat": "node dist/server.js",
    "start:auth": "node dist/auth-admin-server.js",
    "systemd:install": "bash scripts/install-systemd.sh",
    "deploy:one-click": "bash scripts/one-click-deploy.sh",
    "test": "npm run test:integration",
    "test:unit": "npm run build && node --test tests/unit/*.unit.test.js",
    "test:fast": "npm run build && node --test tests/unit/*.unit.test.js tests/integration/chat-server-runtime-contract.integration.test.js tests/integration/chat-server-service-boundaries.integration.test.js tests/integration/chat-server-session-service-boundaries.integration.test.js tests/integration/chat-server-ops-boundaries.integration.test.js",
    "test:integration": "npm run build && node --test tests/integration/*.integration.test.js",
    "dev:frontend": "npm run dev -w @agent-co/frontend",
    "build:frontend": "npm run build -w @agent-co/frontend"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "ioredis": "^5.10.0",
    "ws": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/ws": "^8.18.1",
    "ts-node": "^10.9.0",
    "typescript": "^5.9.3"
  },
  "workspaces": [
    "frontend"
  ]
}
