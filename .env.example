# Chat service
PORT=3002
AGENT_CO_AUTH_ENABLED=true
AUTH_ADMIN_BASE_URL=http://127.0.0.1:3003
AGENT_CO_REDIS_REQUIRED=false
AGENT_CO_CALLBACK_TOKEN=dev-callback-token
AGENT_CO_VERBOSE_LOG_DIR=./logs/ai-cli-verbose

# Auth admin service
AUTH_ADMIN_PORT=3003
AUTH_ADMIN_TOKEN=dev-admin-token-change-me
AGENT_CO_DEFAULT_USER=admin
AGENT_CO_DEFAULT_PASSWORD=admin123!

# Data files
AUTH_DATA_FILE=./data/users.json
AGENT_DATA_FILE=./data/agents.json
