# Chat service
PORT=3002
BOT_ROOM_AUTH_ENABLED=true
AUTH_ADMIN_BASE_URL=http://127.0.0.1:3003
BOT_ROOM_REDIS_REQUIRED=false
BOT_ROOM_CALLBACK_TOKEN=dev-callback-token
